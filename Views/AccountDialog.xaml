<Window x:Class="HomeAccounting.Views.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="440" Height="510" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="16">

        <!-- Кнопки внизу -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,14,0,0">
            <Button x:Name="BtnOk"     Width="110" Height="30" Margin="0,0,16,0"
                    IsDefault="True" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Width="110" Height="30" IsCancel="True"/>
        </StackPanel>

        <!-- Чекбокс над кнопками -->
        <CheckBox x:Name="CbHidden" DockPanel.Dock="Bottom" Margin="0,0,0,10"/>

        <!-- Разделитель -->
        <Separator DockPanel.Dock="Bottom" Margin="-16,0"/>

        <!-- Основное содержимое -->
        <StackPanel>

            <!-- Название счёта -->
            <TextBlock x:Name="TbLblName" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TbName" Padding="8,6" FontSize="13"
                     BorderBrush="#4A90D9" BorderThickness="1.5" Margin="0,0,0,14"/>

            <!-- Иконка  +  Порядковый номер -->
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Иконка -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">
                    <TextBlock x:Name="TbLblIcon" FontWeight="Bold" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CbIcon" FontSize="18" Padding="6,3"/>
                </StackPanel>

                <!-- Порядковый номер (spinner) -->
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TbLblSortOrder" FontWeight="Bold" Margin="0,0,0,4"/>
                    <Grid Width="90">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="22"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="TbSortOrder" Grid.Column="0"
                                 TextAlignment="Center" Padding="4,4"
                                 BorderThickness="1,1,0,1"/>
                        <StackPanel Grid.Column="1">
                            <Button x:Name="BtnOrderUp"   Content="▲" Height="16"
                                    Padding="0" Margin="0" FontSize="8"
                                    Click="BtnOrderUp_Click"/>
                            <Button x:Name="BtnOrderDown" Content="▼" Height="16"
                                    Padding="0" Margin="0,1,0,0" FontSize="8"
                                    Click="BtnOrderDown_Click"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Начальный баланс + Валюта -->
            <TextBlock x:Name="TbLblBalance" FontWeight="Bold" Margin="0,0,0,4"/>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                <TextBox x:Name="TbBalance" Width="220" Padding="8,6" FontSize="13"/>
                <ComboBox x:Name="CbCurrency" Width="100" Margin="8,0,0,0" Padding="6,3" FontSize="13"/>
            </StackPanel>

            <!-- Примечание -->
            <TextBlock x:Name="TbLblNote" FontWeight="Bold" Margin="0,0,0,4"/>
            <TextBox x:Name="TbNote" Height="80" TextWrapping="Wrap"
                     AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                     Padding="6,4" BorderBrush="#ccc"/>

        </StackPanel>
    </DockPanel>
</Window>
