<Window x:Class="HomeAccounting.Views.TransferDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="310" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock x:Name="TbLblDate"   Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <DatePicker                      Grid.Row="0" Grid.Column="1" x:Name="DpDate" Margin="0,0,0,8"/>

        <TextBlock x:Name="TbLblFrom"   Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox                        Grid.Row="1" Grid.Column="1" x:Name="CbFrom" DisplayMemberPath="Name" Margin="0,0,0,8"/>

        <TextBlock x:Name="TbLblTo"     Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <ComboBox                        Grid.Row="2" Grid.Column="1" x:Name="CbTo" DisplayMemberPath="Name" Margin="0,0,0,8"/>

        <TextBlock x:Name="TbLblAmount" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
        <TextBox                         Grid.Row="3" Grid.Column="1" x:Name="TbAmount" Margin="0,0,0,8"/>

        <TextBlock x:Name="TbLblNote"   Grid.Row="4" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,8"/>
        <TextBox                         Grid.Row="4" Grid.Column="1" x:Name="TbNote" AcceptsReturn="True" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BtnOk" Content="OK" Width="80" Margin="0,0,8,0" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Width="80" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>
