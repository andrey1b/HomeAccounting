<Window x:Class="HomeAccounting.Views.DebtsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="860" Height="520" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="TbLblShow" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,8,0"/>
            <ComboBox x:Name="CbKindFilter" Width="180" Padding="6,3"
                      SelectionChanged="CbKindFilter_Changed"/>
            <Button x:Name="BtnAdd"  Width="100" Height="28" Margin="20,0,6,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit" Width="100" Height="28" Margin="0,0,6,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnDel"  Width="100" Height="28" Click="BtnDel_Click"/>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" BorderBrush="#ddd" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,6,0,0">
            <TextBlock x:Name="TbTotal" FontWeight="Bold" HorizontalAlignment="Right"/>
        </Border>

        <DataGrid x:Name="Dg" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  MouseDoubleClick="Dg_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColDate"   Binding="{Binding DateStr}"      Width="90"/>
                <DataGridTextColumn x:Name="ColParty"  Binding="{Binding Counterparty}" Width="*"/>
                <DataGridTextColumn x:Name="ColAcc"    Binding="{Binding AccountName}"  Width="120"/>
                <DataGridTextColumn x:Name="ColAmount" Binding="{Binding AmountStr}"    Width="120"/>
                <DataGridTextColumn x:Name="ColBack"   Binding="{Binding BackStr}"      Width="120"/>
                <DataGridTextColumn x:Name="ColRem"    Binding="{Binding RemainingStr}" Width="120"/>
                <DataGridTextColumn x:Name="ColStatus" Binding="{Binding StatusStr}"    Width="110"/>
                <DataGridTextColumn x:Name="ColNote"   Binding="{Binding Note}"         Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
