<Window x:Class="HomeAccounting.Views.BudgetCopyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="18">
        <TextBlock x:Name="TbLblFrom" FontWeight="Bold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <ComboBox x:Name="CbFromMonth" Width="150" Padding="6,4" Margin="0,0,10,0"/>
            <ComboBox x:Name="CbFromYear"  Width="90"  Padding="6,4"/>
        </StackPanel>

        <TextBlock x:Name="TbLblTo" FontWeight="Bold" Margin="0,0,0,4"/>
        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <ComboBox x:Name="CbToMonth" Width="150" Padding="6,4" Margin="0,0,10,0"/>
            <ComboBox x:Name="CbToYear"  Width="90"  Padding="6,4"/>
        </StackPanel>

        <CheckBox x:Name="ChkExp" IsChecked="True" Margin="0,0,0,6"/>
        <CheckBox x:Name="ChkInc" IsChecked="True" Margin="0,0,0,8"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="BtnOk" Width="110" Height="30" Margin="0,0,16,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Width="110" Height="30" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
