<Window x:Class="HomeAccounting.Views.ImportPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="Self"
        Title="Импорт из xlsx (просмотр)"
        Width="960" Height="620" MinWidth="740" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Выбор файла -->
        <Border Grid.Row="0" Background="#f0f4ff" BorderBrush="#b0c4de"
                BorderThickness="0,0,0,1" Padding="8,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbFileLabel" Grid.Column="0" Text="Файл:"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           FontWeight="SemiBold" Foreground="#34495e"/>
                <TextBox x:Name="TbFilePath" Grid.Column="1" IsReadOnly="True"
                         VerticalAlignment="Center" Background="White"
                         Padding="4,3" FontSize="11"/>
                <Button x:Name="BtnBrowse" Grid.Column="2" Content="Открыть файл..."
                        Click="BtnBrowse_Click" Padding="12,4" Margin="8,0,0,0"/>
            </Grid>
        </Border>

        <!-- Вкладки + кнопка Удалить -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TabControl x:Name="TabImport" Grid.Column="0"
                        SelectionChanged="TabImport_SelectionChanged">

                <!-- ── Счета кратко ── -->
                <TabItem x:Name="TabAcc" Header="Счета кратко">
                    <DataGrid x:Name="DgAcc"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              CanUserSortColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColAccName" Header="Название"
                                Binding="{Binding Name}" Width="220"/>
                            <DataGridTextColumn x:Name="ColAccBal"  Header="Нач. баланс"
                                Binding="{Binding InitBalance, StringFormat=N2}" Width="110"
                                ElementStyle="{StaticResource RightCell}"/>
                            <DataGridTextColumn x:Name="ColAccNote" Header="Примечание"
                                Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ── Расходы ── -->
                <TabItem x:Name="TabExp" Header="Расходы">
                    <DataGrid x:Name="DgExp"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              CanUserSortColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColExpDate" Header="Дата"
                                Binding="{Binding DateStr}" Width="90"/>
                            <DataGridTextColumn x:Name="ColExpAcc"  Header="Счёт"
                                Binding="{Binding Account}" Width="120"/>
                            <DataGridTextColumn x:Name="ColExpCat"  Header="Категория"
                                Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn x:Name="ColExpSub"  Header="Подкатегория"
                                Binding="{Binding Subcategory}" Width="120"/>
                            <DataGridTextColumn x:Name="ColExpUnit" Header="Ед. изм."
                                Binding="{Binding Unit}" Width="65"/>
                            <DataGridTextColumn x:Name="ColExpQty"  Header="Кол-во"
                                Binding="{Binding Qty}" Width="65"/>
                            <DataGridTextColumn x:Name="ColExpAmt"  Header="Сумма"
                                Binding="{Binding Amount, StringFormat=N2}" Width="90"
                                ElementStyle="{StaticResource RightCell}"/>
                            <DataGridTextColumn x:Name="ColExpNote" Header="Примечание"
                                Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ── Доходы ── -->
                <TabItem x:Name="TabInc" Header="Доходы">
                    <DataGrid x:Name="DgInc"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              CanUserSortColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColIncDate" Header="Дата"
                                Binding="{Binding DateStr}" Width="90"/>
                            <DataGridTextColumn x:Name="ColIncAcc"  Header="Счёт"
                                Binding="{Binding Account}" Width="120"/>
                            <DataGridTextColumn x:Name="ColIncCat"  Header="Категория"
                                Binding="{Binding Category}" Width="120"/>
                            <DataGridTextColumn x:Name="ColIncSub"  Header="Подкатегория"
                                Binding="{Binding Subcategory}" Width="120"/>
                            <DataGridTextColumn x:Name="ColIncQty"  Header="Кол-во"
                                Binding="{Binding Qty}" Width="65"/>
                            <DataGridTextColumn x:Name="ColIncUnit" Header="Ед. изм."
                                Binding="{Binding Unit}" Width="65"/>
                            <DataGridTextColumn x:Name="ColIncAmt"  Header="Сумма"
                                Binding="{Binding Amount, StringFormat=N2}" Width="90"
                                ElementStyle="{StaticResource RightCell}"/>
                            <DataGridTextColumn x:Name="ColIncNote" Header="Примечание"
                                Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

                <!-- ── Счета подробно (формат ДомБух7) ── -->
                <TabItem x:Name="TabDet" Header="Счета подробно">
                    <DataGrid x:Name="DgDet"
                              AutoGenerateColumns="False" IsReadOnly="False"
                              CanUserSortColumns="False"
                              ScrollViewer.HorizontalScrollBarVisibility="Auto">
                        <DataGrid.Columns>
                            <DataGridTextColumn x:Name="ColDetDate" Header="Дата"
                                Binding="{Binding DateStr}" Width="90"/>
                            <DataGridTextColumn x:Name="ColDetAcc"  Header="Счёт"
                                Binding="{Binding AccountName}" Width="150"/>
                            <DataGridTextColumn x:Name="ColDetExp"  Header="Расход,₴"
                                Binding="{Binding Expense, StringFormat=N2}" Width="90"
                                ElementStyle="{StaticResource RedCell}"/>
                            <DataGridTextColumn x:Name="ColDetInc"  Header="Доход,₴"
                                Binding="{Binding Income, StringFormat=N2}" Width="90"
                                ElementStyle="{StaticResource GreenCell}"/>
                            <DataGridTextColumn x:Name="ColDetOth"  Header="Прочие,₴"
                                Binding="{Binding Other, StringFormat=N2}" Width="90"
                                ElementStyle="{StaticResource RightCell}"/>
                            <DataGridTextColumn x:Name="ColDetTurn" Header="Оборот,₴"
                                Binding="{Binding Turnover, StringFormat=N2}" Width="90"
                                IsReadOnly="True"
                                ElementStyle="{StaticResource RightCell}"/>
                            <DataGridTextColumn x:Name="ColDetNote" Header="Примечание"
                                Binding="{Binding Note}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </TabItem>

            </TabControl>

            <!-- Кнопки правой панели -->
            <StackPanel Grid.Column="1" Margin="6,8,8,8" VerticalAlignment="Top"
                        Width="90">
                <Button x:Name="BtnEdit"   Content="Изменить"
                        Click="BtnEdit_Click"   Padding="0,6" Margin="0,0,0,6"/>
                <Button x:Name="BtnDelete" Content="Удалить"
                        Click="BtnDelete_Click" Padding="0,6" Margin="0,0,0,6"/>
                <Button x:Name="BtnDelAll" Content="Удалить все"
                        Click="BtnDelAll_Click" Padding="0,6"/>
            </StackPanel>
        </Grid>

        <!-- Статус + кнопки -->
        <Border Grid.Row="2" Background="#f5f5f5" BorderBrush="#ddd"
                BorderThickness="0,1,0,0" Padding="8,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TbStatus" Grid.Column="0"
                           VerticalAlignment="Center" FontSize="11"
                           Foreground="#555" Text="Строк: 0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="BtnImport" Content="Импортировать"
                            Click="BtnImport_Click" Padding="18,5" Margin="0,0,8,0"
                            Background="#1b5e20" Foreground="White"
                            FontWeight="SemiBold" BorderBrush="#1b5e20"/>
                    <Button x:Name="BtnClose" Content="Закрыть"
                            Click="BtnClose_Click" Padding="14,5"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
