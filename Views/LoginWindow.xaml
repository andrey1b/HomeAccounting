<Window x:Class="HomeAccounting.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="360" SizeToContent="Height"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        ShowInTaskbar="True">
    <StackPanel Margin="22">
        <TextBlock x:Name="TbTitle" FontSize="17" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,18"/>

        <TextBlock x:Name="TbLblUser" FontWeight="Bold" Margin="0,0,0,4"/>
        <ComboBox x:Name="CbUser" DisplayMemberPath="Name" FontSize="14"
                  Padding="6,5" Margin="0,0,0,14"
                  SelectionChanged="CbUser_SelectionChanged"/>

        <TextBlock x:Name="TbLblPassword" FontWeight="Bold" Margin="0,0,0,4"/>
        <PasswordBox x:Name="PbPassword" FontSize="14" Padding="6,5"
                     Margin="0,0,0,6" KeyDown="PbPassword_KeyDown"/>

        <TextBlock x:Name="TbError" Foreground="#C0392B" Margin="0,0,0,10"
                   Visibility="Collapsed" TextWrapping="Wrap"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
            <Button x:Name="BtnOk" Width="120" Height="32" Margin="0,0,14,0"
                    IsDefault="True" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Width="120" Height="32"
                    IsCancel="True" Click="BtnCancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>
