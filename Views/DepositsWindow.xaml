<Window x:Class="HomeAccounting.Views.DepositsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="780" Height="500" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnAdd"  Width="100" Height="28" Margin="0,0,6,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit" Width="100" Height="28" Margin="0,0,6,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnDel"  Width="100" Height="28" Click="BtnDel_Click"/>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" BorderBrush="#ddd" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,6,0,0">
            <TextBlock x:Name="TbTotal" FontWeight="Bold" HorizontalAlignment="Right"/>
        </Border>

        <DataGrid x:Name="Dg" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  MouseDoubleClick="Dg_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColName"   Binding="{Binding Name}"        Width="*"/>
                <DataGridTextColumn x:Name="ColAcc"    Binding="{Binding AccountName}" Width="120"/>
                <DataGridTextColumn x:Name="ColAmount" Binding="{Binding AmountStr}"   Width="130"/>
                <DataGridTextColumn x:Name="ColRate"   Binding="{Binding RateStr}"     Width="90"/>
                <DataGridTextColumn x:Name="ColOpen"   Binding="{Binding OpenStr}"     Width="100"/>
                <DataGridTextColumn x:Name="ColClose"  Binding="{Binding CloseStr}"    Width="100"/>
                <DataGridTextColumn x:Name="ColNote"   Binding="{Binding Note}"        Width="160"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
