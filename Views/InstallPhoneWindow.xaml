<Window x:Class="HomeAccounting.Views.InstallPhoneWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="380" Height="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">

    <StackPanel Margin="20" HorizontalAlignment="Center">

        <!-- Step 1 label -->
        <TextBlock x:Name="TbStep1" TextAlignment="Center"
                   FontSize="13" Foreground="#555"
                   Margin="0,0,0,8" TextWrapping="Wrap"/>

        <!-- QR code image -->
        <Image x:Name="ImgQr" Width="280" Height="280"
               RenderOptions.BitmapScalingMode="NearestNeighbor"
               Margin="0,0,0,8"/>

        <!-- URL (copyable) -->
        <TextBlock x:Name="TbUrlLabel" TextAlignment="Center"
                   FontSize="12" Foreground="#888" Margin="0,0,0,2"/>
        <TextBox  x:Name="TbUrl" IsReadOnly="True" TextAlignment="Center"
                  FontSize="12" Foreground="#1565c0"
                  Background="Transparent" BorderThickness="0"
                  Cursor="Hand" TextWrapping="Wrap"
                  Margin="0,0,0,12"
                  PreviewMouseDown="TbUrl_Click"/>

        <!-- Hint after install -->
        <TextBlock x:Name="TbHint" TextAlignment="Center"
                   FontSize="12" Foreground="#2e7d32"
                   TextWrapping="Wrap" Margin="0,0,0,0"/>

    </StackPanel>
</Window>
