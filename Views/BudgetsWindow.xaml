<Window x:Class="HomeAccounting.Views.BudgetsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="760" Height="520" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock x:Name="TbLblYear" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,6,0"/>
            <ComboBox x:Name="CbYear" Width="80" Padding="6,3" SelectionChanged="Filter_Changed"/>
            <TextBlock x:Name="TbLblMonth" VerticalAlignment="Center" FontWeight="Bold" Margin="14,0,6,0"/>
            <ComboBox x:Name="CbMonth" Width="120" Padding="6,3" SelectionChanged="Filter_Changed"/>
            <TextBlock x:Name="TbLblType" VerticalAlignment="Center" FontWeight="Bold" Margin="14,0,6,0"/>
            <ComboBox x:Name="CbType" Width="110" Padding="6,3" SelectionChanged="Filter_Changed"/>
            <Button x:Name="BtnAdd"  Width="90" Height="28" Margin="20,0,6,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnEdit" Width="90" Height="28" Margin="0,0,6,0" Click="BtnEdit_Click"/>
            <Button x:Name="BtnDel"  Width="90" Height="28" Click="BtnDel_Click"/>
        </StackPanel>

        <Border DockPanel.Dock="Bottom" BorderBrush="#ddd" BorderThickness="0,1,0,0" Padding="0,6,0,0" Margin="0,6,0,0">
            <TextBlock x:Name="TbTotal" FontWeight="Bold" HorizontalAlignment="Right"/>
        </Border>

        <DataGrid x:Name="Dg" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column"
                  GridLinesVisibility="Horizontal" RowHeaderWidth="0"
                  MouseDoubleClick="Dg_DoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColCat"  Binding="{Binding CategoryName}"    Width="*"/>
                <DataGridTextColumn x:Name="ColSub"  Binding="{Binding SubcategoryName}" Width="*"/>
                <DataGridTextColumn x:Name="ColPlan" Binding="{Binding PlanStr}"  Width="120"/>
                <DataGridTextColumn x:Name="ColFact" Binding="{Binding FactStr}"  Width="120"/>
                <DataGridTextColumn x:Name="ColDiff" Binding="{Binding DiffStr}"  Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
