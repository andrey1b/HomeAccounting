<Window x:Class="HomeAccounting.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="560" Height="420" WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="BtnAdd"     Width="90"  Height="28" Margin="0,0,6,0" Click="BtnAdd_Click"/>
            <Button x:Name="BtnRename"  Width="90"  Height="28" Margin="0,0,6,0" Click="BtnRename_Click"/>
            <Button x:Name="BtnPass"    Width="130" Height="28" Margin="0,0,6,0" Click="BtnPass_Click"/>
            <Button x:Name="BtnDefault" Width="140" Height="28" Margin="0,0,6,0" Click="BtnDefault_Click"/>
            <Button x:Name="BtnDel"     Width="90"  Height="28" Click="BtnDel_Click"/>
        </StackPanel>
        <DataGrid x:Name="Dg" AutoGenerateColumns="False" IsReadOnly="True"
                  CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                  GridLinesVisibility="Horizontal">
            <DataGrid.Columns>
                <DataGridTextColumn x:Name="ColName" Binding="{Binding Name}" Width="*"/>
                <DataGridCheckBoxColumn x:Name="ColPass" Binding="{Binding HasPassword}" Width="120"/>
                <DataGridCheckBoxColumn x:Name="ColDef"  Binding="{Binding IsDefault}"   Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
