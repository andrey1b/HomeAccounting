<Window x:Class="HomeAccounting.Views.BudgetDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="16">
        <Grid Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="90"/><ColumnDefinition Width="10"/><ColumnDefinition Width="90"/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
                <TextBlock x:Name="TbLblType" FontWeight="Bold" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbType" Padding="6,4" SelectionChanged="CbType_Changed"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock x:Name="TbLblYear" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBox x:Name="TbYear" Padding="6,4"/>
            </StackPanel>
            <StackPanel Grid.Column="4">
                <TextBlock x:Name="TbLblMonth" FontWeight="Bold" Margin="0,0,0,4"/>
                <ComboBox x:Name="CbMonth" Padding="6,4"/>
            </StackPanel>
        </Grid>

        <TextBlock x:Name="TbLblCategory" FontWeight="Bold" Margin="0,0,0,4"/>
        <ComboBox x:Name="CbCategory" DisplayMemberPath="Name" Margin="0,0,0,12" Padding="6,4"
                  SelectionChanged="CbCategory_Changed"/>

        <TextBlock x:Name="TbLblSub" FontWeight="Bold" Margin="0,0,0,4"/>
        <ComboBox x:Name="CbSub" DisplayMemberPath="Name" Margin="0,0,0,12" Padding="6,4"/>

        <TextBlock x:Name="TbLblPlan" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox x:Name="TbPlan" Margin="0,0,0,12" Padding="6,4"/>

        <TextBlock x:Name="TbLblNote" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBox x:Name="TbNote" Height="46" TextWrapping="Wrap" AcceptsReturn="True" Padding="6,4"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <Button x:Name="BtnOk" Width="110" Height="30" Margin="0,0,16,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Width="110" Height="30" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
