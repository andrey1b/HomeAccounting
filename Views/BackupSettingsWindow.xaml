<Window x:Class="HomeAccounting.Views.BackupSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <StackPanel Margin="18">
        <CheckBox x:Name="ChkEnable" FontWeight="Bold" Margin="0,0,0,14"/>

        <TextBlock x:Name="TbLblFolder" FontWeight="Bold" Margin="0,0,0,4"/>
        <Grid Margin="0,0,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBox x:Name="TbFolder" Grid.Column="0" Padding="6,5" VerticalContentAlignment="Center"/>
            <Button   x:Name="BtnBrowse" Grid.Column="1" Width="100" Height="30" Margin="8,0,0,0" Click="BtnBrowse_Click"/>
        </Grid>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
            <TextBlock x:Name="TbLblKeep" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="TbKeep" Width="70" Padding="6,5" TextAlignment="Center"/>
        </StackPanel>

        <Button x:Name="BtnBackupNow" Height="30" HorizontalAlignment="Left" Width="200" Margin="0,0,0,6" Click="BtnBackupNow_Click"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,14,0,0">
            <Button x:Name="BtnOk" Width="110" Height="32" Margin="0,0,16,0" IsDefault="True" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Width="110" Height="32" IsCancel="True"/>
        </StackPanel>
    </StackPanel>
</Window>
