<Window x:Class="HomeAccounting.Views.IncomeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="460" Height="390" WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="16">

        <!-- Кнопки внизу -->
        <Grid DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BtnMore"   Grid.Column="1" Width="110" Click="BtnMore_Click"/>
            <Button x:Name="BtnOk"     Grid.Column="2" Content="OK" Width="90" Click="BtnOk_Click"/>
            <Button x:Name="BtnCancel" Grid.Column="3" Width="90"   IsCancel="True"/>
        </Grid>

        <!-- Разделитель -->
        <Separator DockPanel.Dock="Bottom" Margin="-16,0"/>

        <!-- Форма -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="140"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TbLblDate"        Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <DatePicker                           Grid.Row="0" Grid.Column="1" x:Name="DpDate" Margin="0,0,0,8"/>

            <TextBlock x:Name="TbLblAccount"     Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <ComboBox                             Grid.Row="1" Grid.Column="1" x:Name="CbAccount" DisplayMemberPath="Name" Margin="0,0,0,8"/>

            <TextBlock x:Name="TbLblCategory"    Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <ComboBox                             Grid.Row="2" Grid.Column="1" x:Name="CbCategory" DisplayMemberPath="Name"
                                                  SelectionChanged="CbCategory_SelectionChanged" Margin="0,0,0,8"/>

            <TextBlock x:Name="TbLblSubcategory" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <ComboBox                             Grid.Row="3" Grid.Column="1" x:Name="CbSubcategory" DisplayMemberPath="Name" Margin="0,0,0,8"/>

            <TextBlock x:Name="TbLblAmount"      Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <TextBox                              Grid.Row="4" Grid.Column="1" x:Name="TbAmount" Margin="0,0,0,8" Padding="6,4"/>

            <TextBlock x:Name="TbLblQty"         Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,0,8"/>
            <Grid                                 Grid.Row="5" Grid.Column="1" Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="110"/>
                </Grid.ColumnDefinitions>
                <TextBox  Grid.Column="0" x:Name="TbQty" Margin="0,0,6,0" Text="1" Padding="6,4"/>
                <ComboBox Grid.Column="1" x:Name="CbUnit" DisplayMemberPath="Name"/>
            </Grid>

            <TextBlock x:Name="TbLblNote"        Grid.Row="6" Grid.Column="0" VerticalAlignment="Top" Margin="0,4,0,0"/>
            <TextBox                              Grid.Row="6" Grid.Column="1" x:Name="TbNote"
                                                  AcceptsReturn="True" TextWrapping="Wrap"
                                                  VerticalScrollBarVisibility="Auto"
                                                  Padding="6,4" BorderBrush="#ccc"/>
        </Grid>
    </DockPanel>
</Window>
