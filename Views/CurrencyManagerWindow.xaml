<Window x:Class="HomeAccounting.Views.CurrencyManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="640" Height="480" WindowStartupLocation="CenterOwner">
    <TabControl Margin="8" x:Name="Tabs">
        <TabItem x:Name="TabCur">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnCurAdd"  Width="90"  Height="28" Margin="0,0,6,0" Click="BtnCurAdd_Click"/>
                    <Button x:Name="BtnCurEdit" Width="90"  Height="28" Margin="0,0,6,0" Click="BtnCurEdit_Click"/>
                    <Button x:Name="BtnCurDel"  Width="90"  Height="28" Margin="0,0,6,0" Click="BtnCurDel_Click"/>
                    <Button x:Name="BtnCurDef"  Width="160" Height="28" Click="BtnCurDef_Click"/>
                </StackPanel>
                <DataGrid x:Name="DgCur" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal" MouseDoubleClick="DgCur_DoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColCode" Binding="{Binding Code}"   Width="80"/>
                        <DataGridTextColumn x:Name="ColCName" Binding="{Binding Name}"   Width="*"/>
                        <DataGridTextColumn x:Name="ColSym"  Binding="{Binding Symbol}"  Width="80"/>
                        <DataGridCheckBoxColumn x:Name="ColDef" Binding="{Binding IsDefault}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>
        <TabItem x:Name="TabRates">
            <DockPanel Margin="8">
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                    <Button x:Name="BtnRateAdd" Width="90" Height="28" Margin="0,0,6,0" Click="BtnRateAdd_Click"/>
                    <Button x:Name="BtnRateDel" Width="90" Height="28" Margin="0,0,6,0" Click="BtnRateDel_Click"/>
                    <Button x:Name="BtnRateDownload" Width="180" Height="28" Click="BtnRateDownload_Click"/>
                </StackPanel>
                <DataGrid x:Name="DgRates" AutoGenerateColumns="False" IsReadOnly="True"
                          CanUserAddRows="False" HeadersVisibility="Column" RowHeaderWidth="0"
                          GridLinesVisibility="Horizontal">
                    <DataGrid.Columns>
                        <DataGridTextColumn x:Name="ColRDate" Binding="{Binding DateStr}"      Width="120"/>
                        <DataGridTextColumn x:Name="ColRCur"  Binding="{Binding CurrencyName}" Width="*"/>
                        <DataGridTextColumn x:Name="ColRVal"  Binding="{Binding RateStr}"      Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </TabItem>
    </TabControl>
</Window>
