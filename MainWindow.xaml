<Window x:Class="HomeAccounting.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HomeAccounting"
        Width="1100" Height="680" MinWidth="820" MinHeight="520"
        WindowStartupLocation="CenterScreen"
        Loaded="MainWindow_Loaded" Closing="MainWindow_Closing">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="LinkButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,2,0"/>
        </Style>
        <Style x:Key="IconCell" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem x:Name="MiFile">
                <MenuItem x:Name="MiImportPreview"  Click="MiImportPreview_Click"/>
                <Separator/>
                <MenuItem x:Name="MiImportAccounts" Click="MiImportAccounts_Click"/>
                <MenuItem x:Name="MiImportExpenses" Click="MiImportExpenses_Click"/>
                <MenuItem x:Name="MiImportIncomes"  Click="MiImportIncomes_Click"/>
                <Separator/>
                <MenuItem x:Name="MiExportAccounts" Click="MiExportAccounts_Click"/>
                <MenuItem x:Name="MiExportExpenses" Click="MiExportExpenses_Click"/>
                <MenuItem x:Name="MiExportIncomes"  Click="MiExportIncomes_Click"/>
                <Separator/>
                <MenuItem x:Name="MiLoadQr"      Click="MiLoadQr_Click"/>
                <MenuItem x:Name="MiInstallPhone" Click="MiInstallPhone_Click"/>
                <Separator/>
                <MenuItem x:Name="MiExit" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem x:Name="MiRefs">
                <MenuItem x:Name="MiCatsExp" Click="MenuCatsExpense_Click"/>
                <MenuItem x:Name="MiCatsInc" Click="MenuCatsIncome_Click"/>
            </MenuItem>
            <MenuItem x:Name="MiReports" Click="MenuReports_Click"/>
            <MenuItem x:Name="MiMaint">
                <MenuItem x:Name="MiClearDb"  Click="MiClearDb_Click"/>
                <MenuItem x:Name="MiVacuumDb" Click="MiVacuumDb_Click"/>
            </MenuItem>
            <MenuItem x:Name="MiLang">
                <MenuItem x:Name="MiLangRu" Tag="ru" IsCheckable="True" IsChecked="True" Click="MiLang_Click"/>
                <MenuItem x:Name="MiLangEn" Tag="en" IsCheckable="True" Click="MiLang_Click"/>
            </MenuItem>
        </Menu>

        <!-- Баннер обновления (скрыт до появления новой версии) -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Bottom"
                Background="#1565c0" Padding="10,5"
                Visibility="Collapsed" Cursor="Hand"
                MouseDown="UpdateBanner_MouseDown">
            <TextBlock x:Name="TbUpdateBanner"
                       Foreground="White" FontSize="12" FontWeight="SemiBold"
                       TextAlignment="Center"/>
        </Border>

        <!-- Status bar -->
        <StatusBar x:Name="SbMain" DockPanel.Dock="Bottom" Height="22">
            <StatusBarItem>
                <TextBlock x:Name="TbStatus" FontSize="11" Foreground="#555"/>
            </StatusBarItem>
        </StatusBar>

        <!-- QR-коды: Android + iPhone -->
        <Border DockPanel.Dock="Right" Width="158"
                BorderBrush="#c5e0c5" BorderThickness="1,0,0,0"
                Background="#f0faf0" Padding="10,14,10,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel HorizontalAlignment="Center">

                    <!-- ── Android ── -->
                    <TextBlock Text="&#x1F4F1; Android"
                               FontSize="10" FontWeight="Bold" Foreground="#1a6b1a"
                               TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Установка ComfortBuh:"
                               FontSize="9" Foreground="#4a8a4a"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,8"/>
                    <Image x:Name="ImgPhoneQr" Width="128" Height="128"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           Cursor="Hand" ToolTip="Нажмите для подробной инструкции"
                           MouseDown="ImgPhoneQr_MouseDown"/>
                    <TextBlock x:Name="TbPhoneQrUrl" FontSize="8" Foreground="#888"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="(нажмите для инструкции)" FontSize="7.5" Foreground="#bbb"
                               TextAlignment="Center" Margin="0,2,0,0"/>

                    <!-- ── Разделитель ── -->
                    <Separator Margin="0,12"/>

                    <!-- ── iPhone ── -->
                    <TextBlock Text="&#xF8FF; iPhone / браузер"
                               FontSize="10" FontWeight="Bold" Foreground="#0055aa"
                               TextAlignment="Center" Margin="0,0,0,4"/>
                    <TextBlock Text="Открыть в Safari:"
                               FontSize="9" Foreground="#4466aa"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,8"/>
                    <Image x:Name="ImgIphoneQr" Width="128" Height="128"
                           RenderOptions.BitmapScalingMode="NearestNeighbor"
                           ToolTip="Откройте в браузере Safari на iPhone"/>
                    <TextBlock x:Name="TbIphoneQrUrl" FontSize="8" Foreground="#888"
                               TextWrapping="Wrap" TextAlignment="Center" Margin="0,4,0,0"/>
                    <TextBlock Text="(веб-форма для отправки чека)" FontSize="7.5" Foreground="#bbb"
                               TextAlignment="Center" Margin="0,2,0,0"/>

                    <!-- ── Разделитель ── -->
                    <Separator Margin="0,12"/>

                    <!-- ── Счёт по умолчанию ── -->
                    <TextBlock x:Name="TbReceiptAccountLbl" FontSize="10" FontWeight="SemiBold"
                               Foreground="#2e7d32" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CbReceiptAccount" Width="136" DisplayMemberPath="Name"
                              SelectionChanged="CbReceiptAccount_SelectionChanged"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Main tabs -->
        <TabControl x:Name="MainTabs" SelectionChanged="MainTabs_SelectionChanged">

            <!-- ===== ACCOUNTS TAB ===== -->
            <TabItem x:Name="TabAccounts">
                <TabControl x:Name="AccSubTabs" SelectionChanged="AccSubTabs_SelectionChanged" Margin="2">

                    <!-- Sub: Overview -->
                    <TabItem x:Name="TabAccBrief">
                        <DockPanel Margin="8">

                            <!-- Нижняя панель: кнопки управления + итоговый баланс -->
                            <Border DockPanel.Dock="Bottom" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                                    Padding="8,6" Margin="0,6,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Кнопки слева -->
                                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                        <Button x:Name="BtnAddAccount"    Click="BtnAddAccount_Click"/>
                                        <Button x:Name="BtnEditAccount"   Click="BtnEditAccount_Click"/>
                                        <Button x:Name="BtnHideAccount"   Click="BtnHideAccount_Click"/>
                                        <Button x:Name="BtnDeleteAccount" Click="BtnDeleteAccount_Click"/>
                                        <CheckBox x:Name="CbShowHiddenAccounts" VerticalAlignment="Center"
                                                  Margin="6,0,0,0"
                                                  Checked="RefreshAccounts" Unchecked="RefreshAccounts"/>
                                    </WrapPanel>

                                    <!-- Итоговый баланс справа -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock x:Name="TbTotalBalanceLbl" FontWeight="Bold" Margin="0,0,4,0"/>
                                        <TextBlock x:Name="TbTotalBalance"    FontWeight="Bold" Foreground="DarkGreen"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <DataGrid x:Name="DgAccounts" AutoGenerateColumns="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"                                      MouseDoubleClick="DgAccounts_DoubleClick"
                                      SelectionChanged="DgAccounts_SelectionChanged"
                                      LoadingRow="DgAccounts_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn x:Name="ColAccNum"     Binding="{Binding RowNumber}"  Width="36"/>
                                    <DataGridTextColumn x:Name="ColAccIcon"    Binding="{Binding Icon}"       Width="44"
                                                        ElementStyle="{StaticResource IconCell}"/>
                                    <DataGridTextColumn x:Name="ColAccName"    Width="2*"/>
                                    <DataGridTextColumn x:Name="ColAccExpense" Binding="{Binding ExpenseStr}" Width="130"
                                                        ElementStyle="{StaticResource RedCell}"/>
                                    <DataGridTextColumn x:Name="ColAccIncome"  Binding="{Binding IncomeStr}"  Width="130"
                                                        ElementStyle="{StaticResource GreenCell}"/>
                                    <DataGridTextColumn x:Name="ColAccBalance" Binding="{Binding BalanceStr}" Width="130"
                                                        ElementStyle="{StaticResource GreenCell}"/>
                                    <DataGridTextColumn x:Name="ColAccNote"    Binding="{Binding Note}"       Width="3*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                    <!-- Sub: Detailed -->
                    <TabItem x:Name="TabAccDetailed">
                        <DockPanel Margin="8">

                            <!-- Filter -->
                            <Border DockPanel.Dock="Bottom" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                                    Padding="6,4" Margin="0,4,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TbDetFromLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <DatePicker x:Name="DpDetFrom" Width="112" Margin="0,0,6,0"
                                                    SelectedDateChanged="DetFilter_Changed"/>
                                        <TextBlock x:Name="TbDetToLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <DatePicker x:Name="DpDetTo" Width="112" Margin="0,0,6,0"
                                                    SelectedDateChanged="DetFilter_Changed"/>
                                        <TextBlock x:Name="TbDetAccountLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                        <ComboBox x:Name="CbDetAccount" Width="110" DisplayMemberPath="Name"
                                                  SelectionChanged="DetFilter_Changed"/>
                                    </WrapPanel>
                                    <CheckBox x:Name="CbDetFilter" Grid.Column="1" IsChecked="False"
                                              VerticalAlignment="Center" Margin="8,0,0,0"
                                              Checked="DetFilter_Changed" Unchecked="DetFilter_Changed"/>
                                </Grid>
                            </Border>

                            <!-- Data table with resizable columns -->
                            <DataGrid x:Name="DgDetailed"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      CanUserSortColumns="False"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      RowDetailsVisibilityMode="Collapsed"
                                      LoadingRow="DgDetailed_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Width="32" CanUserResize="False">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding ExpandBtn}"
                                                        Width="22" Height="18" Margin="4,0"
                                                        Background="Transparent" BorderBrush="#aaa"
                                                        BorderThickness="1" FontFamily="Consolas"
                                                        FontSize="11"
                                                        Click="BtnDetToggle_Click"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn x:Name="ColDetDate" Binding="{Binding DateStr}"     Width="100"/>
                                    <DataGridTextColumn x:Name="ColDetAcc"  Binding="{Binding AccountName}" Width="300"/>
                                    <DataGridTextColumn x:Name="ColDetExp"  Binding="{Binding ExpStr}"      Width="130"
                                                        ElementStyle="{StaticResource RedCell}"/>
                                    <DataGridTextColumn x:Name="ColDetInc"  Binding="{Binding IncStr}"      Width="130"
                                                        ElementStyle="{StaticResource GreenCell}"/>
                                </DataGrid.Columns>
                                <DataGrid.RowDetailsTemplate>
                                    <DataTemplate>
                                        <Border Background="#f5f8ff" Margin="32,0,4,4" Padding="8,4"
                                                BorderBrush="#b8d0f0" BorderThickness="1" CornerRadius="4">
                                            <ItemsControl ItemsSource="{Binding Sections}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Margin="0,2,0,4">
                                                            <TextBlock Text="{Binding Title}"
                                                                       FontWeight="Bold" FontSize="11"
                                                                       Foreground="#34495e" Margin="0,0,0,2"/>
                                                            <ItemsControl ItemsSource="{Binding Items}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Margin="4,1">
                                                                            <Grid.ColumnDefinitions>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                                <ColumnDefinition Width="110"/>
                                                                                <ColumnDefinition Width="*"/>
                                                                            </Grid.ColumnDefinitions>
                                                                            <TextBlock Grid.Column="0" Text="{Binding Col1}" VerticalAlignment="Center"/>
                                                                            <TextBlock Grid.Column="1" Text="{Binding Col2}" VerticalAlignment="Center" Foreground="#777"/>
                                                                            <TextBlock Grid.Column="2" Text="{Binding AmountStr}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                                                            <TextBlock Grid.Column="3" Text="{Binding Note}" Margin="8,0,0,0" VerticalAlignment="Center" Foreground="#999"/>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Border>
                                    </DataTemplate>
                                </DataGrid.RowDetailsTemplate>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                    <!-- Sub: Transfers -->
                    <TabItem x:Name="TabAccTransfers">
                        <DockPanel Margin="8">
                            <ToolBar DockPanel.Dock="Top" Margin="0,0,0,6">
                                <Button x:Name="BtnAddTransfer"    Style="{StaticResource LinkButton}" Click="BtnAddTransfer_Click"/>
                                <Button x:Name="BtnEditTransfer"   Style="{StaticResource LinkButton}" Click="BtnEditTransfer_Click"/>
                                <Button x:Name="BtnDeleteTransfer" Style="{StaticResource LinkButton}" Click="BtnDeleteTransfer_Click"/>
                            </ToolBar>

                            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,6">
                                <CheckBox x:Name="CbTrFilter" IsChecked="False" VerticalAlignment="Center"
                                          Margin="0,0,6,0"
                                          Checked="TrFilter_Changed" Unchecked="TrFilter_Changed"/>
                                <TextBlock x:Name="TbTrFromLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="DpTrFrom" Width="120" Margin="0,0,8,0" SelectedDateChanged="TrFilter_Changed"/>
                                <TextBlock x:Name="TbTrToLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="DpTrTo" Width="120" SelectedDateChanged="TrFilter_Changed"/>
                            </WrapPanel>

                            <Border DockPanel.Dock="Bottom" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                                    Padding="8,4" Margin="0,8,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TbTrTotalLbl" FontWeight="Bold" Margin="0,0,4,0"/>
                                    <TextBlock x:Name="TbTrTotal" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>

                            <DataGrid x:Name="DgTransfers" AutoGenerateColumns="False" IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"                                      MouseDoubleClick="DgTransfers_DoubleClick"
                                      SelectionChanged="DgTransfers_SelectionChanged"
                                      LoadingRow="DgTransfers_LoadingRow">
                                <DataGrid.Columns>
                                    <DataGridTextColumn x:Name="ColTrDate"   Binding="{Binding DateStr}"         Width="90"/>
                                    <DataGridTextColumn x:Name="ColTrFrom"   Binding="{Binding FromAccountName}" Width="*"/>
                                    <DataGridTextColumn x:Name="ColTrTo"     Binding="{Binding ToAccountName}"   Width="*"/>
                                    <DataGridTextColumn x:Name="ColTrAmount" Binding="{Binding AmountStr}"       Width="110"
                                                        ElementStyle="{StaticResource RightCell}"/>
                                    <DataGridTextColumn x:Name="ColTrNote"   Binding="{Binding Note}"            Width="2*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </TabItem>

                </TabControl>
            </TabItem>

            <!-- ===== EXPENSES TAB ===== -->
            <TabItem x:Name="TabExpenses">
                <Border Background="#dde3ec" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>     <!-- таблица -->
                        <RowDefinition Height="Auto"/>  <!-- фильтр -->
                        <RowDefinition Height="Auto"/>  <!-- кнопки + итоги -->
                    </Grid.RowDefinitions>

                    <!-- Таблица расходов -->
                    <Border Grid.Row="0" BorderBrush="#555" BorderThickness="1" Margin="0,0,0,4">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" Background="#f5f5f5"
                                    BorderBrush="#bbb" BorderThickness="0,1,0,0" Padding="6,3">
                                <Grid>
                                    <TextBlock x:Name="TbExpRowCount" FontWeight="Bold" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TbExpRowTotal" FontWeight="Bold" FontSize="11"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Foreground="#c0392b"/>
                                </Grid>
                            </Border>
                            <DataGrid x:Name="DgvExpenses"
                                      AutoGenerateColumns="False"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      IsReadOnly="True"
                                      CanUserSortColumns="False"
                                      SelectionChanged="DgExpenses_SelectionChanged"
                                      LoadingRow="DgExpenses_LoadingRow"
                                      MouseDoubleClick="DgExpenses_DoubleClick"
                                      KeyDown="DgExpenses_KeyDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding DateStr}"         Width="100"/>
                                    <DataGridTextColumn Binding="{Binding AccountName}"     Width="130"/>
                                    <DataGridTextColumn Binding="{Binding CategoryName}"    Width="150"/>
                                    <DataGridTextColumn Binding="{Binding SubcategoryName}" Width="150"/>
                                    <DataGridTextColumn Binding="{Binding UnitName}"        Width="70"/>
                                    <DataGridTextColumn Binding="{Binding QtyStr}"          Width="65"
                                                        ElementStyle="{StaticResource RightCell}"/>
                                    <DataGridTextColumn Binding="{Binding AmountStr}"       Width="105"
                                                        ElementStyle="{StaticResource RedCell}"/>
                                    <DataGridTextColumn Binding="{Binding Note}"            Width="600"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Фильтр -->
                    <Border Grid.Row="1" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                            Padding="6,4" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="TbExpFromLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="DpExpFrom" Width="112" Margin="0,0,6,0"
                                            SelectedDateChanged="ExpFilter_Changed"/>
                                <TextBlock x:Name="TbExpToLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="DpExpTo" Width="112" Margin="0,0,6,0"
                                            SelectedDateChanged="ExpFilter_Changed"/>
                                <TextBlock x:Name="TbExpAccountLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CbExpAccount" Width="110" DisplayMemberPath="Name" Margin="0,0,6,0"
                                          SelectionChanged="ExpFilter_Changed"/>
                                <TextBlock x:Name="TbExpCategoryLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CbExpCategory" Width="110" DisplayMemberPath="Name" Margin="0,0,6,0"
                                          SelectionChanged="CbExpCategory_SelectionChanged"/>
                                <TextBlock x:Name="TbExpSubcategoryLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CbExpSubcategory" Width="110" DisplayMemberPath="Name"
                                          SelectionChanged="ExpFilter_Changed"/>
                            </WrapPanel>
                            <CheckBox x:Name="CbExpFilter" Grid.Column="1" IsChecked="False"
                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                      Checked="ExpFilter_Changed" Unchecked="ExpFilter_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Кнопки + Итоги -->
                    <Border Grid.Row="2" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                            Padding="6,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnAddExpense"    Click="BtnAddExpense_Click"/>
                                <Button x:Name="BtnEditExpense"   Click="BtnEditExpense_Click"/>
                                <Button x:Name="BtnDeleteExpense" Click="BtnDeleteExpense_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="A-" Width="32" Padding="0" FontWeight="Bold"
                                        ToolTip="Уменьшить шрифт таблицы"
                                        Click="BtnFontMinus_Click"/>
                                <Button Content="A+" Width="32" Padding="0" FontWeight="Bold"
                                        ToolTip="Увеличить шрифт таблицы"
                                        Click="BtnFontPlus_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TbExpTodayLbl"  FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbExpToday"     Margin="0,0,12,0"/>
                                <TextBlock x:Name="TbExpWeekLbl"   FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbExpWeek"      Margin="0,0,12,0"/>
                                <TextBlock x:Name="TbExpMonthLbl"  FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbExpMonth"     Margin="0,0,12,0"/>
                                <TextBlock x:Name="TbExpFilterLbl" FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbExpTotal"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                </Border>
            </TabItem>

            <!-- ===== INCOMES TAB ===== -->
            <TabItem x:Name="TabIncomes">
                <Border Background="#dde3ec" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>     <!-- таблица -->
                        <RowDefinition Height="Auto"/>  <!-- фильтр -->
                        <RowDefinition Height="Auto"/>  <!-- кнопки + итоги -->
                    </Grid.RowDefinitions>

                    <!-- Таблица доходов -->
                    <Border Grid.Row="0" BorderBrush="#555" BorderThickness="1" Margin="0,0,0,4">
                        <DockPanel>
                            <Border DockPanel.Dock="Bottom" Background="#f5f5f5"
                                    BorderBrush="#bbb" BorderThickness="0,1,0,0" Padding="6,3">
                                <Grid>
                                    <TextBlock x:Name="TbIncRowCount" FontWeight="Bold" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TbIncRowTotal" FontWeight="Bold" FontSize="11"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                               Foreground="#1a7a1a"/>
                                </Grid>
                            </Border>
                            <DataGrid x:Name="DgvIncomes"
                                      AutoGenerateColumns="False"
                                      ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                      IsReadOnly="True"
                                      CanUserSortColumns="False"
                                      SelectionChanged="DgIncomes_SelectionChanged"
                                      LoadingRow="DgIncomes_LoadingRow"
                                      MouseDoubleClick="DgIncomes_DoubleClick"
                                      KeyDown="DgIncomes_KeyDown">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding DateStr}"         Width="100"/>
                                    <DataGridTextColumn Binding="{Binding AccountName}"     Width="130"/>
                                    <DataGridTextColumn Binding="{Binding CategoryName}"    Width="150"/>
                                    <DataGridTextColumn Binding="{Binding SubcategoryName}" Width="150"/>
                                    <DataGridTextColumn Binding="{Binding QtyStr}"          Width="65"
                                                        ElementStyle="{StaticResource RightCell}"/>
                                    <DataGridTextColumn Binding="{Binding UnitName}"        Width="70"/>
                                    <DataGridTextColumn Binding="{Binding AmountStr}"       Width="105"
                                                        ElementStyle="{StaticResource GreenCell}"/>
                                    <DataGridTextColumn Binding="{Binding Note}"            Width="600"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>

                    <!-- Фильтр -->
                    <Border Grid.Row="1" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                            Padding="6,4" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <WrapPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock x:Name="TbIncFromLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="DpIncFrom" Width="112" Margin="0,0,6,0"
                                            SelectedDateChanged="IncFilter_Changed"/>
                                <TextBlock x:Name="TbIncToLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <DatePicker x:Name="DpIncTo" Width="112" Margin="0,0,6,0"
                                            SelectedDateChanged="IncFilter_Changed"/>
                                <TextBlock x:Name="TbIncAccountLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CbIncAccount" Width="110" DisplayMemberPath="Name" Margin="0,0,6,0"
                                          SelectionChanged="IncFilter_Changed"/>
                                <TextBlock x:Name="TbIncCategoryLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CbIncCategory" Width="110" DisplayMemberPath="Name" Margin="0,0,6,0"
                                          SelectionChanged="CbIncCategory_SelectionChanged"/>
                                <TextBlock x:Name="TbIncSubcategoryLbl" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <ComboBox x:Name="CbIncSubcategory" Width="110" DisplayMemberPath="Name"
                                          SelectionChanged="IncFilter_Changed"/>
                            </WrapPanel>
                            <CheckBox x:Name="CbIncFilter" Grid.Column="1" IsChecked="False"
                                      VerticalAlignment="Center" Margin="8,0,0,0"
                                      Checked="IncFilter_Changed" Unchecked="IncFilter_Changed"/>
                        </Grid>
                    </Border>

                    <!-- Кнопки + Итоги -->
                    <Border Grid.Row="2" BorderBrush="#ccc" BorderThickness="1" CornerRadius="4"
                            Padding="6,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnAddIncome"    Click="BtnAddIncome_Click"/>
                                <Button x:Name="BtnEditIncome"   Click="BtnEditIncome_Click"/>
                                <Button x:Name="BtnDeleteIncome" Click="BtnDeleteIncome_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                        HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Button Content="A-" Width="32" Padding="0" FontWeight="Bold"
                                        ToolTip="Уменьшить шрифт таблицы"
                                        Click="BtnFontMinus_Click"/>
                                <Button Content="A+" Width="32" Padding="0" FontWeight="Bold"
                                        ToolTip="Увеличить шрифт таблицы"
                                        Click="BtnFontPlus_Click"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TbIncTodayLbl"  FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbIncToday"     Margin="0,0,12,0"/>
                                <TextBlock x:Name="TbIncWeekLbl"   FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbIncWeek"      Margin="0,0,12,0"/>
                                <TextBlock x:Name="TbIncMonthLbl"  FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbIncMonth"     Margin="0,0,12,0"/>
                                <TextBlock x:Name="TbIncFilterLbl" FontWeight="Bold" Margin="0,0,2,0"/>
                                <TextBlock x:Name="TbIncTotal"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
                </Border>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
